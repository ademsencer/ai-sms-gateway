# ============================================================
# Application
# ============================================================
NODE_ENV=development
API_PORT=3000
API_PREFIX=api
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# ============================================================
# Database (MySQL)
# ============================================================
DATABASE_URL=mysql://smsgateway:smsgateway_password@localhost:3306/sms_gateway_db
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=sms_gateway_db
MYSQL_USER=smsgateway
MYSQL_PASSWORD=smsgateway_password
MYSQL_PORT=3306

# ============================================================
# Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=smsgw:

# ============================================================
# RabbitMQ
# ============================================================
RABBITMQ_URL=amqp://smsgateway:smsgateway_password@localhost:5672
RABBITMQ_USER=smsgateway
RABBITMQ_PASSWORD=smsgateway_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ============================================================
# Telegram (optional)
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# ============================================================
# JWT / Auth
# ============================================================
JWT_ACCESS_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ============================================================
# Device Settings
# ============================================================
DEVICE_HEARTBEAT_TTL=120
DEVICE_HEARTBEAT_CHECK_INTERVAL=30000
SMS_DEDUP_TTL=300
